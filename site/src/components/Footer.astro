---
/**
 * Footer de la landing page de Alfred Dev.
 *
 * Renderiza la informacion institucional del proyecto: nombre, version,
 * licencia, enlaces a GitHub y documentacion tecnica, tagline
 * descriptivo, slogan final y descargo de responsabilidad con popup.
 *
 * Los datos se reciben como props tipadas desde FooterData, lo que
 * permite reutilizar el componente en distintos idiomas sin cambiar
 * la estructura HTML.
 *
 * @example
 * ```astro
 * <Footer {...data.footer} />
 * ```
 */

import type { FooterData } from '@/types';

interface Props extends FooterData {}

const { version, license, githubUrl, docsUrl, tagline, slogan, disclaimer } = Astro.props;
---

<footer>
  <div class="container">
    <p>
      <strong class="footer-name">Alfred Dev</strong> {version}
      <span class="footer-sep">|</span>
      {license}
      <span class="footer-sep">|</span>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-sep">|</span>
      <a href={docsUrl} target="_blank" rel="noopener noreferrer">Documentacion tecnica</a>
    </p>
    <p class="footer-tagline">
      Plugin de <a href="https://docs.anthropic.com/en/docs/claude-code" target="_blank" rel="noopener noreferrer">Claude Code</a>.
      {' '}{tagline.replace('Plugin de Claude Code. ', '').replace('Claude Code plugin. ', '')}
    </p>
    <p class="footer-slogan">{slogan}</p>
    <p class="footer-disclaimer">
      <button type="button" class="disclaimer-link" id="disclaimerOpen">
        {disclaimer.linkText}
      </button>
    </p>
  </div>

  <!-- Modal de descargo de responsabilidad -->
  <div class="disclaimer-overlay" id="disclaimerOverlay" aria-hidden="true">
    <div class="disclaimer-modal" role="dialog" aria-modal="true" aria-labelledby="disclaimerTitle">
      <div class="disclaimer-header">
        <h3 id="disclaimerTitle">{disclaimer.title}</h3>
        <button type="button" class="disclaimer-close" id="disclaimerClose" aria-label={disclaimer.closeText}>
          &#10005;
        </button>
      </div>
      <div class="disclaimer-body" set:html={disclaimer.contentHtml} />
      <div class="disclaimer-footer">
        <button type="button" class="disclaimer-btn" id="disclaimerBtn">
          {disclaimer.closeText}
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  function initDisclaimer(): void {
    const openBtn = document.getElementById('disclaimerOpen');
    const overlay = document.getElementById('disclaimerOverlay');
    const closeBtn = document.getElementById('disclaimerClose');
    const closeFooterBtn = document.getElementById('disclaimerBtn');

    if (!openBtn || !overlay || !closeBtn || !closeFooterBtn) return;

    function open(): void {
      overlay!.classList.add('active');
      overlay!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close(): void {
      overlay!.classList.remove('active');
      overlay!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    closeFooterBtn.addEventListener('click', close);

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay!.classList.contains('active')) {
        close();
      }
    });
  }

  initDisclaimer();
</script>

<style>
  /* -- Footer ------------------------------------------------- */
  footer {
    padding: 48px 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  footer p {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.8;
  }

  footer a {
    color: var(--blue);
    text-decoration: underline;
    text-decoration-color: var(--border-light);
    text-underline-offset: 2px;
  }

  footer a:hover {
    color: var(--text-bright);
    text-decoration-color: var(--text-bright);
  }

  /* -- Nombre del proyecto ------------------------------------ */
  .footer-name {
    color: var(--text);
  }

  /* -- Separador visual --------------------------------------- */
  .footer-sep {
    margin: 0 8px;
    color: var(--border-light);
  }

  /* -- Tagline descriptivo ------------------------------------ */
  .footer-tagline {
    margin-top: 8px;
  }

  /* -- Slogan final ------------------------------------------- */
  .footer-slogan {
    margin-top: 24px;
    font-size: 12px;
    color: var(--text-muted);
  }

  /* -- Enlace de descargo ------------------------------------- */
  .footer-disclaimer {
    margin-top: 16px;
  }

  .disclaimer-link {
    background: none;
    border: none;
    color: var(--text-dim);
    font-size: 11px;
    font-family: inherit;
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--border-light);
    text-underline-offset: 2px;
    padding: 0;
    transition: color 0.2s;
  }

  .disclaimer-link:hover {
    color: var(--text-muted);
    text-decoration-color: var(--text-muted);
  }

  /* -- Overlay del modal -------------------------------------- */
  .disclaimer-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .disclaimer-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* -- Modal -------------------------------------------------- */
  .disclaimer-modal {
    background: var(--bg-card, #12141c);
    border: 1px solid var(--border);
    border-radius: 12px;
    max-width: 580px;
    width: 90%;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    transform: translateY(16px);
    transition: transform 0.3s ease;
  }

  .disclaimer-overlay.active .disclaimer-modal {
    transform: translateY(0);
  }

  .disclaimer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid var(--border);
  }

  .disclaimer-header h3 {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-bright);
    margin: 0;
  }

  .disclaimer-close {
    background: none;
    border: none;
    color: var(--text-dim);
    font-size: 16px;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    transition: color 0.2s;
  }

  .disclaimer-close:hover {
    color: var(--text-bright);
  }

  .disclaimer-body {
    padding: 20px 24px;
    overflow-y: auto;
    font-size: 13px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .disclaimer-body :global(p) {
    margin-bottom: 12px;
  }

  .disclaimer-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .disclaimer-body :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .disclaimer-body :global(a) {
    color: var(--blue);
    text-decoration: underline;
    text-decoration-color: var(--border-light);
    text-underline-offset: 2px;
  }

  .disclaimer-body :global(a:hover) {
    color: var(--text-bright);
  }

  .disclaimer-footer {
    padding: 16px 24px 20px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: flex-end;
  }

  .disclaimer-btn {
    background: var(--bg-hover, rgba(91, 156, 245, 0.08));
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-size: 13px;
    font-family: inherit;
    padding: 8px 20px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .disclaimer-btn:hover {
    background: rgba(91, 156, 245, 0.12);
    border-color: var(--blue);
  }
</style>
