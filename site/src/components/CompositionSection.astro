---
/**
 * Seccion de composicion dinamica con demo de terminal interactiva.
 *
 * Simula una interaccion real en Claude Code: el usuario escribe un
 * comando, Alfred muestra el equipo de nucleo, presenta dos bloques
 * de seleccion de agentes opcionales (multiSelect) y finalmente
 * formula una pregunta del Product Owner (singleSelect).
 *
 * La animacion tiene cinco fases secuenciales:
 *
 * 1. Typing: escribe el comando caracter a caracter.
 * 2. Core team: muestra el mensaje informativo del equipo base.
 * 3. Tech agents: pregunta multiSelect con checkboxes animados.
 * 4. Content agents: segunda pregunta multiSelect.
 * 5. Confirm + Product question: confirmacion y pregunta del PO.
 *
 * Respeta prefers-reduced-motion mostrando el estado final sin animacion.
 *
 * @example
 * ```astro
 * <CompositionSection composition={data.composition} />
 * ```
 */
import type { CompositionSection } from '@/types';
import SectionHeader from '@/components/ui/SectionHeader.astro';

interface Props {
  composition: CompositionSection;
}

const { composition } = Astro.props;

/**
 * Serializa los datos de la demo como JSON para el script del cliente.
 * Incluye las opciones de los tres selectores para animar las selecciones.
 */
const demoData = JSON.stringify({
  techOptions: composition.techOptions,
  contentOptions: composition.contentOptions,
  productOptions: composition.productOptions,
});
---

<section id="composicion" class="composition-section">
  <div class="container">
    <SectionHeader
      label={composition.header.label}
      labelColor={composition.header.labelColor}
      title={composition.header.title}
      description={composition.header.description}
    />

    <p class="composition-intro fade-in" set:html={composition.introHtml} />

    <!-- Terminal de la demo -->
    <div class="composition-demo fade-in">
      <div class="terminal" aria-label="Terminal demo">
        <div class="terminal-header">
          <span class="terminal-dot terminal-dot--red"></span>
          <span class="terminal-dot terminal-dot--yellow"></span>
          <span class="terminal-dot terminal-dot--green"></span>
          <span class="terminal-title">terminal</span>
        </div>

        <div class="terminal-body" id="compositionTerminal">
          <!-- Fase 1: comando con typing -->
          <div class="term-line">
            <span class="term-prompt">{composition.terminalPrompt}</span>
          </div>
          <div class="term-line term-command">
            <span class="term-text" id="termText" data-full-text={composition.terminalText}></span>
            <span class="term-cursor" id="termCursor">|</span>
          </div>

          <!-- Fase 2: equipo de nucleo -->
          <div class="term-block hidden" id="blockCore">
            <div class="term-info">
              <span class="term-info-icon" aria-hidden="true">&#9654;</span>
              <span>{composition.coreTeamText}</span>
            </div>
          </div>

          <!-- Fase 3: multiSelect tecnico -->
          <div class="term-block hidden" id="blockTech">
            <div class="term-question">
              <span class="term-q-icon" aria-hidden="true">?</span>
              <span>{composition.techQuestion}</span>
            </div>
            <div class="term-options" id="optionsTech">
              {composition.techOptions.map((opt, i) => (
                <div
                  class="term-option"
                  data-selected={opt.selected ? 'true' : 'false'}
                  data-index={i}
                >
                  <span class="term-checkbox" aria-hidden="true">
                    <span class="cb-box"></span>
                    <span class="cb-check">&#10003;</span>
                  </span>
                  <span class="term-opt-label">{opt.label}</span>
                  <span class="term-opt-desc">{opt.desc}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Fase 4: multiSelect contenido -->
          <div class="term-block hidden" id="blockContent">
            <div class="term-question">
              <span class="term-q-icon" aria-hidden="true">?</span>
              <span>{composition.contentQuestion}</span>
            </div>
            <div class="term-options" id="optionsContent">
              {composition.contentOptions.map((opt, i) => (
                <div
                  class="term-option"
                  data-selected={opt.selected ? 'true' : 'false'}
                  data-index={i}
                >
                  <span class="term-checkbox" aria-hidden="true">
                    <span class="cb-box"></span>
                    <span class="cb-check">&#10003;</span>
                  </span>
                  <span class="term-opt-label">{opt.label}</span>
                  <span class="term-opt-desc">{opt.desc}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Fase 5a: confirmacion -->
          <div class="term-block hidden" id="blockConfirm">
            <div class="term-confirm">
              <span class="term-confirm-icon" aria-hidden="true">&#10003;</span>
              <span>{composition.confirmText}</span>
            </div>
          </div>

          <!-- Fase 5b: pregunta del Product Owner -->
          <div class="term-block hidden" id="blockProduct">
            <div class="term-question term-question--po">
              <span class="term-q-icon term-q-icon--po" aria-hidden="true">?</span>
              <span>{composition.productQuestion}</span>
            </div>
            <div class="term-options" id="optionsProduct">
              {composition.productOptions.map((opt, i) => (
                <div
                  class="term-option term-option--radio"
                  data-selected={opt.selected ? 'true' : 'false'}
                  data-index={i}
                >
                  <span class="term-radio" aria-hidden="true">
                    <span class="radio-ring"></span>
                    <span class="radio-dot"></span>
                  </span>
                  <span class="term-opt-label">{opt.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  /**
   * Animacion de la demo de composicion en terminal.
   *
   * Terminal con altura fija, scroll automatico hacia abajo conforme
   * aparece contenido nuevo, y bucle infinito: al terminar la secuencia
   * se reinicia tras una pausa.
   */

  const textEl = document.getElementById('termText') as HTMLSpanElement | null;
  const cursorEl = document.getElementById('termCursor') as HTMLSpanElement | null;
  const sectionEl = document.getElementById('composicion') as HTMLElement | null;
  const termBody = document.getElementById('compositionTerminal') as HTMLElement | null;

  const blockIds = ['blockCore', 'blockTech', 'blockContent', 'blockConfirm', 'blockProduct'];
  const optionGroupIds = ['optionsTech', 'optionsContent', 'optionsProduct'];

  const blocks = blockIds.map(id => document.getElementById(id));

  if (textEl && cursorEl && sectionEl && termBody && blocks.every(Boolean)) {
    const fullText = textEl.dataset.fullText || '';

    /** Scroll suave al final del terminal. */
    function scrollToBottom(): void {
      termBody!.scrollTo({ top: termBody!.scrollHeight, behavior: 'smooth' });
    }

    /** Muestra un bloque con animacion de entrada y hace scroll. */
    function showBlock(block: HTMLElement): Promise<void> {
      return new Promise((resolve) => {
        block.classList.remove('hidden');
        block.classList.add('visible');
        scrollToBottom();
        setTimeout(resolve, 400);
      });
    }

    /** Anima las selecciones de un grupo de opciones. */
    function animateSelections(containerId: string): Promise<void> {
      return new Promise((resolve) => {
        const container = document.getElementById(containerId);
        if (!container) { resolve(); return; }

        const options = container.querySelectorAll('.term-option[data-selected="true"]');
        let i = 0;

        function selectNext(): void {
          if (i >= options.length) {
            setTimeout(resolve, 300);
            return;
          }
          (options[i] as HTMLElement).classList.add('checked');
          scrollToBottom();
          i++;
          setTimeout(selectNext, 250);
        }

        setTimeout(selectNext, 300);
      });
    }

    /** Efecto typing caracter a caracter. */
    function startTyping(): Promise<void> {
      return new Promise((resolve) => {
        let charIndex = 0;
        const speed = 22;

        function typeNext(): void {
          if (charIndex > fullText.length) {
            cursorEl!.classList.add('blink');
            setTimeout(resolve, 500);
            return;
          }
          textEl!.textContent = fullText.slice(0, charIndex);
          charIndex++;
          setTimeout(typeNext, speed);
        }

        typeNext();
      });
    }

    /** Reinicia todo al estado inicial para volver a animar. */
    function resetState(): void {
      textEl!.textContent = '';
      cursorEl!.classList.remove('blink');
      cursorEl!.style.display = 'none';

      for (const block of blocks) {
        block!.classList.remove('visible');
        block!.classList.add('hidden');
      }

      for (const id of optionGroupIds) {
        const container = document.getElementById(id);
        if (!container) continue;
        container.querySelectorAll('.term-option.checked').forEach(opt => {
          (opt as HTMLElement).classList.remove('checked');
        });
      }

      termBody!.scrollTop = 0;
    }

    /** Secuencia principal de la animacion (una iteracion). */
    async function runAnimation(): Promise<void> {
      resetState();
      cursorEl!.style.display = 'inline';

      await startTyping();
      cursorEl!.style.display = 'none';

      await showBlock(blocks[0]!);
      await new Promise(r => setTimeout(r, 600));

      await showBlock(blocks[1]!);
      await animateSelections('optionsTech');
      await new Promise(r => setTimeout(r, 400));

      await showBlock(blocks[2]!);
      await animateSelections('optionsContent');
      await new Promise(r => setTimeout(r, 400));

      await showBlock(blocks[3]!);
      await new Promise(r => setTimeout(r, 600));

      await showBlock(blocks[4]!);
      await animateSelections('optionsProduct');

      /* Pausa antes de reiniciar el bucle */
      await new Promise(r => setTimeout(r, 3000));
    }

    /** Bucle infinito de la animacion. */
    async function loopAnimation(): Promise<void> {
      while (true) {
        await runAnimation();
      }
    }

    /** Estado final sin animacion (prefers-reduced-motion). */
    function showFinalState(): void {
      textEl!.textContent = fullText;
      cursorEl!.style.display = 'none';

      for (const block of blocks) {
        block!.classList.remove('hidden');
        block!.classList.add('visible');
      }

      for (const id of optionGroupIds) {
        const container = document.getElementById(id);
        if (!container) continue;
        container.querySelectorAll('.term-option[data-selected="true"]').forEach(opt => {
          (opt as HTMLElement).classList.add('checked');
        });
      }
    }

    /* Lanzar al entrar en viewport */
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let hasStarted = false;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !hasStarted) {
            hasStarted = true;
            observer.disconnect();
            if (prefersReducedMotion) {
              showFinalState();
            } else {
              loopAnimation();
            }
          }
        }
      },
      { threshold: 0.15 }
    );

    observer.observe(sectionEl);
  }
</script>

<style>
  /* -- Seccion ------------------------------------------------ */
  .composition-section {
    padding: 80px 0 40px;
  }

  .composition-intro {
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.7;
    max-width: 720px;
    margin-bottom: 40px;
  }

  /* -- Terminal ----------------------------------------------- */
  .composition-demo {
    max-width: 760px;
  }

  .terminal {
    background: #0d0f14;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    font-family: var(--font-mono);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: #12141c;
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal-dot--red { background: #e5564f; }
  .terminal-dot--yellow { background: #e8a44a; }
  .terminal-dot--green { background: #4ec990; }

  .terminal-title {
    margin-left: 8px;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .terminal-body {
    padding: 24px 24px 28px;
    height: 380px;
    overflow-y: hidden;
  }

  /* -- Lineas de terminal ------------------------------------- */
  .term-line {
    line-height: 1.8;
  }

  .term-prompt {
    color: var(--green);
    font-size: 14px;
    font-weight: 600;
  }

  .term-command {
    margin-top: 4px;
  }

  .term-text {
    color: var(--text);
    font-size: 14px;
    line-height: 1.8;
    word-break: break-word;
  }

  .term-cursor {
    color: var(--blue);
    font-weight: 700;
    font-size: 15px;
    opacity: 1;
  }

  .term-cursor.blink {
    animation: cursorBlink 1s step-end infinite;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* -- Bloques animados --------------------------------------- */
  .term-block {
    margin-top: 16px;
    transition: opacity 0.5s ease, transform 0.4s ease;
  }

  .term-block.hidden {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    max-height: 0;
    overflow: hidden;
    margin-top: 0;
  }

  .term-block.visible {
    opacity: 1;
    transform: translateY(0);
    max-height: 600px;
    margin-top: 16px;
  }

  /* -- Mensaje informativo (equipo de nucleo) ----------------- */
  .term-info {
    display: flex;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(91, 156, 245, 0.06);
    border: 1px solid rgba(91, 156, 245, 0.12);
    border-radius: 6px;
    font-size: 12px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .term-info-icon {
    color: var(--blue);
    font-size: 8px;
    margin-top: 4px;
    flex-shrink: 0;
  }

  /* -- Preguntas (multiSelect / singleSelect) ----------------- */
  .term-question {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .term-q-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(78, 201, 144, 0.15);
    color: var(--green);
    font-size: 10px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .term-q-icon--po {
    background: rgba(160, 126, 232, 0.15);
    color: var(--purple, #a07ee8);
  }

  .term-question span:last-child {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-bright);
  }

  .term-question--po span:last-child {
    color: var(--purple, #a07ee8);
  }

  /* -- Opciones ----------------------------------------------- */
  .term-options {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-left: 26px;
  }

  .term-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 10px;
    border-radius: 4px;
    transition: background 0.3s;
  }

  .term-option.checked {
    background: rgba(78, 201, 144, 0.06);
  }

  .term-option--radio.checked {
    background: rgba(160, 126, 232, 0.06);
  }

  /* -- Checkbox ----------------------------------------------- */
  .term-checkbox {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .cb-box {
    display: block;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--border);
    border-radius: 3px;
    background: transparent;
    transition: background 0.3s, border-color 0.3s;
  }

  .cb-check {
    position: absolute;
    color: transparent;
    font-size: 10px;
    font-weight: 700;
    transition: color 0.3s;
    line-height: 1;
  }

  .term-option.checked .cb-box {
    background: var(--green);
    border-color: var(--green);
  }

  .term-option.checked .cb-check {
    color: #fff;
  }

  /* -- Radio -------------------------------------------------- */
  .term-radio {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .radio-ring {
    display: block;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--border);
    border-radius: 50%;
    transition: border-color 0.3s;
  }

  .radio-dot {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: transparent;
    transition: background 0.3s;
  }

  .term-option--radio.checked .radio-ring {
    border-color: var(--purple, #a07ee8);
  }

  .term-option--radio.checked .radio-dot {
    background: var(--purple, #a07ee8);
  }

  /* -- Labels de opciones ------------------------------------- */
  .term-opt-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
  }

  .term-option.checked .term-opt-label {
    color: var(--text-bright);
  }

  .term-opt-desc {
    font-size: 11px;
    color: var(--text-dim);
    margin-left: 4px;
  }

  .term-option.checked .term-opt-desc {
    color: var(--text-muted);
  }

  /* -- Confirmacion ------------------------------------------- */
  .term-confirm {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: rgba(78, 201, 144, 0.06);
    border: 1px solid rgba(78, 201, 144, 0.15);
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--green);
  }

  .term-confirm-icon {
    font-size: 12px;
  }

  /* -- Responsive 768px --------------------------------------- */
  @media (max-width: 768px) {
    .composition-section {
      padding: 60px 0 32px;
    }

    .terminal-body {
      padding: 18px 14px 22px;
      height: 340px;
    }

    .term-prompt,
    .term-text {
      font-size: 13px;
    }

    .term-options {
      padding-left: 18px;
    }

    .term-opt-desc {
      display: none;
    }
  }

  /* -- Responsive 480px --------------------------------------- */
  @media (max-width: 480px) {
    .terminal-body {
      padding: 14px 10px 18px;
      height: 300px;
    }

    .term-prompt,
    .term-text {
      font-size: 12px;
    }

    .term-question span:last-child {
      font-size: 12px;
    }

    .term-opt-label {
      font-size: 11px;
    }
  }
</style>
